{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akmaestro.internal/schemas/feature-state.schema.json",
  "title": "AKMaestro feature workflow state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "revision",
    "featureId",
    "title",
    "phase",
    "currentStory",
    "stories",
    "gates",
    "history",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": { "const": "../../schemas/feature-state.schema.json" },
    "version": { "const": 3 },
    "revision": { "type": "integer", "minimum": 0 },
    "featureId": { "$ref": "#/$defs/featureId" },
    "title": { "type": "string", "minLength": 1 },
    "phase": {
      "enum": [
        "understanding",
        "framing",
        "splitting",
        "story_loop",
        "reviewing",
        "retrospective",
        "complete"
      ]
    },
    "currentStory": {
      "oneOf": [{ "$ref": "#/$defs/storyId" }, { "type": "null" }]
    },
    "stories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "step", "mode", "reviewAttempts"],
        "properties": {
          "id": { "$ref": "#/$defs/storyId" },
          "step": {
            "enum": ["prime", "plan", "implement", "review", "learn", "complete"]
          },
          "mode": { "enum": ["guided", "autonomous"] },
          "reviewAttempts": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "approvedAt"],
        "properties": {
          "name": {
            "enum": ["understand", "frame", "split", "feature-review", "retro"]
          },
          "approvedAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["revision", "event", "from", "to", "at"],
        "properties": {
          "revision": { "type": "integer", "minimum": 1 },
          "event": { "type": "string", "minLength": 1 },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "featureId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,99}$"
    },
    "storyId": {
      "type": "string",
      "pattern": "^[0-9]{2,}-[a-z0-9][a-z0-9-]{0,99}$"
    }
  }
}
