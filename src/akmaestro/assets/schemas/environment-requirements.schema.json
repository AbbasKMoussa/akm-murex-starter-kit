{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akmaestro.internal/schemas/environment-requirements.schema.json",
  "title": "AKMaestro developer environment requirements",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "revision",
    "tools",
    "artifacts",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "$schema": {
      "const": "../schemas/environment-requirements.schema.json"
    },
    "version": { "const": 3 },
    "revision": { "type": "integer", "minimum": 0 },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/tool" }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "required", "probe"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "probe": {
          "type": "object",
          "additionalProperties": false,
          "required": ["command"],
          "properties": {
            "command": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "cwd": { "type": "string", "minLength": 1 },
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1,
              "maximum": 120
            },
            "contains": { "type": "string", "minLength": 1 }
          }
        },
        "install": { "$ref": "#/$defs/action" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "required"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "path": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "remediation": { "$ref": "#/$defs/action" }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "cwd": { "type": "string", "minLength": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 3600 }
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,99}$"
    }
  }
}
